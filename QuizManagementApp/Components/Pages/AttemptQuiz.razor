@page "/student/attempt/{QuizId:int}/{QuizStartTimeTicks:long}"
@rendermode InteractiveServer

@inject YourApp.Data.AppDbContext _context
@inject YourApp.Services.sessionService sessionService
@inject NavigationManager navigationManager

<div style="margin-bottom: 20px;">
    <button class="btn btn-secondary" @onclick="GoBackToQuizzes">Back to Quizzes</button>
</div>

<h3>@quiz?.Title</h3>

@if (quiz != null)
{
    <div>
        <p><strong>Duration:</strong> @quiz.Duration minutes</p>
        <p><strong>Start Time:</strong> @quiz.StartTime</p>
        @if (!string.IsNullOrEmpty(quiz.remarks))
        {
            <p><strong>Remarks:</strong> @quiz.remarks</p>
        }
    </div>

    <hr />

    @if (questions != null && questions.Count > 0)
    {
        <form>
            @foreach (var question in questions)
            {
                <div style="margin-bottom: 20px; padding: 15px; border: 1px solid #ddd;">
                    <h4>@question.QuestionText</h4>

                    @{
                        var questionOptions = options.Where(o => o.QuestionID == question.QuestionID).ToList();

                        if (quiz.ShuffleOptions)
                        {
                            Random rng = new Random();
                            questionOptions = questionOptions.OrderBy(o => rng.Next()).ToList();
                        }
                    }

                    @foreach (var option in questionOptions)
                    {
                        <div style="margin: 10px 0;">
                            <input type="radio" id="option_@option.OptionID" name="question_@question.QuestionID"
                                   value="@option.OptionID"
                                   @onchange="@((ChangeEventArgs e) => SelectAnswer(question.QuestionID, int.Parse(e.Value.ToString())))" />
                            <label for="option_@option.OptionID">@option.OptionText</label>
                        </div>
                    }
                </div>
            }
        </form>

        <hr />

        <button class="btn btn-success" @onclick="SubmitQuiz" disabled="@(!showSubmit)">Submit Quiz</button>
        @if (!showSubmit)
        {
            <button class="btn btn-primary" @onclick="GoBackToDashboard">Go Back to Dashboard</button>
        }
        <p style="color:green">@successMessage</p>
        <p style="color:red">@errorMessage</p>
    }
    else
    {
        <p>No questions available for this quiz.</p>
    }
}
else
{
    <p>Loading quiz...</p>
}

@code {
    [Parameter]
    public int QuizId { get; set; }

    [Parameter]
    public long QuizStartTimeTicks { get; set; }

    DateTime quizStartTime;

    Quiz? quiz;
    List<Question> questions = new();
    List<Option> options = new();
    Dictionary<int, int> studentAnswers = new(); // QuestionID -> SelectedOptionID

    string successMessage = "";
    string errorMessage = "";

    bool showSubmit = true;


    protected override void OnInitialized()
    {
        if (sessionService == null || !sessionService.isLoggedIn || sessionService.CurrentUser?.Role != "Student")
        {
            navigationManager.NavigateTo("/login"); 
            return;
        }

        // Convert ticks back to DateTime
        quizStartTime = new DateTime(QuizStartTimeTicks);

        LoadQuiz();
    }

    void LoadQuiz()
{
    try
    {
        quiz = _context.Quizzes.FirstOrDefault(q => q.QuizID == QuizId);

        if (quiz == null)
        {
            errorMessage = "Quiz not found.";
            return;
        }

        // Load questions
        questions = _context.Questions.Where(q => q.QuizID == QuizId).ToList();

        // Randomize questions if enabled
        if (quiz.RandomizeQuestions)
        {
            Random rng = new Random();
            questions = questions.OrderBy(q => rng.Next()).ToList();
        }

        // Load options
        var questionIds = questions.Select(q => q.QuestionID).ToList();
        options = _context.Options.Where(o => questionIds.Contains(o.QuestionID)).ToList();

        // Randomize options for each question if enabled
        if (quiz.ShuffleOptions)
        {
            Random rng = new Random();
            // Note: ShufflFing options requires handling in the UI rendering
        }
    }
    catch (Exception ex)
    {
        errorMessage = "Error loading quiz: " + ex.Message;
    }
}
    void SelectAnswer(int questionId, int optionId)
    {
        if (studentAnswers.ContainsKey(questionId))
        {
            studentAnswers[questionId] = optionId;
        }
        else
        {
            studentAnswers.Add(questionId, optionId);
        }
    }

    void SubmitQuiz()
    {
        try
        {
            if (quiz == null)
            {
                errorMessage = "Quiz information not available.";
                return;
            }

            if (sessionService?.CurrentUser == null)
            {
                errorMessage = "User information not available.";
                return;
            }

            // Calculate score
            int score = CalculateScore();

            // Create attempt record
            var attempt = new Attempt
            {
                QuizID = QuizId,
                StudentID = sessionService.CurrentUser.UserID,
                StartTime = quizStartTime,
                EndTime = DateTime.Now,
                Score = score
            };

            _context.Attempts.Add(attempt);
            _context.SaveChanges();

            successMessage = "Quiz submitted successfully! Attempt ID: " + attempt.AttemptID + " | Score: " + score;
            errorMessage = "";
            showSubmit = false;
        }
        catch (Exception ex)
        {
            errorMessage = "Error submitting quiz: " + ex.Message;
        }
    }

    int CalculateScore()
    {
        int correctAnswers = 0;

        // For each question, check if the student's answer is correct
        foreach (var kvp in studentAnswers)
        {
            int questionId = kvp.Key;
            int selectedOptionId = kvp.Value;

            // Find the selected option
            var selectedOption = options.FirstOrDefault(o => o.OptionID == selectedOptionId);

            // If the selected option is correct, increment the score
            if (selectedOption != null && selectedOption.IsCorrect)
            {
                correctAnswers++;
            }
        }

        return correctAnswers;
    }

    void GoBackToDashboard()
    {
        navigationManager.NavigateTo("/student");
    }
    void GoBackToQuizzes()
    {
        navigationManager.NavigateTo("/student/quizzes");
    }}
