@page "/teacher/quiz"
@rendermode InteractiveServer

@inject YourApp.Data.AppDbContext _context
@inject YourApp.Services.sessionService Session
@inject NavigationManager NavManager

<h3>Create Quiz</h3>

<input @bind="title" placeholder="Quiz Title" />

<br /><br />

<label>Duration (minutes):</label>
<input type="number" @bind="duration" />

<br /><br />

<label>
    <input type="checkbox" @bind="randomizeQuestions" />
    Randomize Questions
</label>

<br />

<label>
    <input type="checkbox" @bind="shuffleOptions" />
    Shuffle Options
</label>

<hr />

<h4>Select Questions</h4>

@foreach (var q in questions)
{
    <div>
        <input type="checkbox" @onchange="(e => ToggleQuestion(q.QuestionID, e))" />
        @q.QuestionText
    </div>
}

<br />

<button @onclick="CreateQuiz">Create Quiz</button>

<p style="color:green">@message</p>

@code {
    List<Question> questions = new();
    List<int> selectedQuestions = new();

    string title = "";
    int duration = 10;
    bool randomizeQuestions = false;
    bool shuffleOptions = false;
    string message = "";

    protected override void OnInitialized()
    {
        if (!Session.isLoggedIn || Session.CurrentUser.Role != "Teacher")
        {
            NavManager.NavigateTo("/login");
            return;
        }

        questions = _context.Questions.ToList();
    }

    void ToggleQuestion(int id, ChangeEventArgs e)
    {
        bool isChecked = (bool)e.Value;

        if (isChecked)
            selectedQuestions.Add(id);
        else
            selectedQuestions.Remove(id);
    }

    void CreateQuiz()
    {
        try
        {
            var quiz = new Quiz
            {
                Title = title,
                SubjectID = 1, // simplify for now
                CreatedBy = Session.CurrentUser.UserID,
                Duration = duration,
                RandomizeQuestions = randomizeQuestions,
                ShuffleOptions = shuffleOptions
            };

            _context.Quizzes.Add(quiz);
            _context.SaveChanges();

            foreach (var qid in selectedQuestions)
            {
                _context.QuizQuestions.Add(new QuizQuestion
                {
                    QuizID = quiz.QuizID,
                    QuestionID = qid
                });
            }

            _context.SaveChanges();

            message = "Quiz created successfully!";

            // reset
            title = "";
            selectedQuestions.Clear();
        }
        catch (Exception ex)
        {
            message = "Error: " + ex.Message;
        }
    }
}